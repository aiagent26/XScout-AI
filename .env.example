# ==========================================
# XScout AI Onchain OS - Environment Profile
# ==========================================

# 1. AI Language Model Intelligence
OPENAI_API_KEY=sk-your-openai-api-key-here

# 2. Telegram Alerting System
TELEGRAM_BOT_TOKEN=123456789:ABCDEF....

# 3. OKX Onchain OS API (Required for AgenticWalletService)
OKX_ONCHAINOS_API_KEY=your_okx_api_key_here

# 4. AI Agent TEE Wallet (Hot Wallet running on VPS to sign Execution tx)
AI_AGENT_PRIVATE_KEY=0x...YourAgentPrivateKey...
AI_AGENT_PUBLIC_ADDRESS=0x...YourAgentAddress...

# 5. Treasury/Fee Collection Wallet (The 1% commission destination)
TREASURY_PUBLIC_ADDRESS=0x...YourTreasuryColdWallet...
